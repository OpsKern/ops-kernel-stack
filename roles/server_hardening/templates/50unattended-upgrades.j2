// {{ ansible_managed }}
// Role: server_hardening

Unattended-Upgrade::Allowed-Origins {
    "${distro_id}:${distro_codename}-security";
    "${distro_id}ESMApps:${distro_codename}-apps-security";
    "${distro_id}ESM:${distro_codename}-infra-security";
};

Unattended-Upgrade::Package-Blacklist {
};

Unattended-Upgrade::DevRelease "false";
Unattended-Upgrade::AutoFixInterruptedDpkg "true";
Unattended-Upgrade::MinimalSteps "true";
{% if hardening_unattended_upgrades_mail %}
Unattended-Upgrade::Mail "{{ hardening_unattended_upgrades_mail }}";
Unattended-Upgrade::MailReport "on-change";
{% endif %}
Unattended-Upgrade::Remove-Unused-Kernel-Packages "true";
Unattended-Upgrade::Remove-New-Unused-Dependencies "{{ 'true' if hardening_unattended_upgrades_remove_unused_deps else 'false' }}";
Unattended-Upgrade::Remove-Unused-Dependencies "{{ 'true' if hardening_unattended_upgrades_remove_unused_deps else 'false' }}";
Unattended-Upgrade::Automatic-Reboot "{{ 'true' if hardening_unattended_upgrades_auto_reboot else 'false' }}";
Unattended-Upgrade::Automatic-Reboot-Time "{{ hardening_unattended_upgrades_reboot_time }}";
Unattended-Upgrade::SyslogEnable "true";
