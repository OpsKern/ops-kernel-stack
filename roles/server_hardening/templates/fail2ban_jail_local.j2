# {{ ansible_managed }}
# Role: server_hardening

[DEFAULT]
bantime = {{ hardening_fail2ban_bantime }}
findtime = {{ hardening_fail2ban_findtime }}
maxretry = {{ hardening_fail2ban_maxretry }}
ignoreip = {{ hardening_fail2ban_ignoreip }}
{% if hardening_fail2ban_destemail %}
destemail = {{ hardening_fail2ban_destemail }}
{% endif %}
action = {{ hardening_fail2ban_action }}
backend = systemd

[sshd]
enabled = true
port = {{ hardening_ssh_port }}
filter = sshd
maxretry = {{ hardening_fail2ban_maxretry }}
