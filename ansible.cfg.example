[defaults]
inventory          = ./inventory.yml
remote_user        = <YOUR_ANSIBLE_USER>
private_key_file   = <PATH_TO_SSH_KEY>
host_key_checking  = False
retry_files_enabled = False
stdout_callback    = yaml
callback_whitelist = profile_tasks

# Auto-load vault password (copy this file to ansible.cfg and set your path)
vault_password_file = <PATH_TO_VAULT_PASS_FILE>

[privilege_escalation]
become      = True
become_method = sudo
become_user = root
